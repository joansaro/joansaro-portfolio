---
import type { Project } from '../data/profile';
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import DeviceFrame from './DeviceFrame.astro';

interface Props {
  project: Project;
  lang: Lang;
}

const { project, lang } = Astro.props;
const t = useTranslations(lang);
const basePath = lang === 'es' ? '' : '/en';
const galleryItems = project.gallery.filter((src) => src !== project.cover);
---

<article class="mx-auto max-w-5xl px-6 pt-12 pb-24">
  <a
    href={`${basePath}/#projects`}
    class="reveal mb-12 inline-flex items-center gap-2 text-sm text-fg-muted transition-colors hover:text-accent"
  >
    <svg class="h-4 w-4 transition-transform group-hover:-translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="m12 19-7-7 7-7M19 12H5"/>
    </svg>
    {t('projects.backToProjects')}
  </a>

  <header class="reveal mb-12">
    <div class="mb-4 flex flex-wrap items-center gap-3">
      <p class="font-mono text-xs uppercase tracking-[0.25em] text-accent">
        {t('projects.year')} {project.year}
      </p>
      {project.featured && (
        <span class="rounded-full border border-accent/40 bg-accent/10 px-2.5 py-0.5 font-mono text-[10px] uppercase tracking-widest text-accent">
          ★ {t('project.featured')}
        </span>
      )}
      {project.status === 'coming-soon' && (
        <span class="inline-flex items-center gap-1.5 rounded-full border border-emerald-500/30 bg-emerald-500/10 px-2.5 py-0.5 font-mono text-[10px] uppercase tracking-widest text-emerald-600 dark:text-emerald-400">
          <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 dark:bg-emerald-400"></span>
          {lang === 'es' ? 'En producción real' : 'In real production'}
        </span>
      )}
    </div>
    <h1 class="text-balance text-4xl font-semibold tracking-[-0.03em] text-fg sm:text-5xl md:text-6xl">
      {project.title}
    </h1>
    <p class="mt-5 max-w-2xl text-pretty text-lg text-fg-muted sm:text-xl">
      {project.description[lang]}
    </p>

    <div class="mt-8 flex flex-wrap gap-3">
      {project.demo && (
        <a
          href={project.demo}
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-2 rounded-lg bg-accent px-5 py-2.5 text-sm font-medium text-white shadow-lg shadow-accent/20 transition-all hover:-translate-y-0.5 hover:bg-accent-hover"
        >
          {project.status === 'coming-soon' ? (lang === 'es' ? 'Visitar el sitio real' : 'Visit the live site') : t('projects.viewDemo')}
          <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M7 17 17 7M7 7h10v10"/>
          </svg>
        </a>
      )}
      {project.code && (
        <a
          href={project.code}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border border-strong px-5 py-2.5 text-sm font-medium text-fg transition-all hover:-translate-y-0.5 hover:border-accent hover:text-accent"
        >
          {t('projects.viewCode')}
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M16 18l6-6-6-6M8 6l-6 6 6 6"/>
          </svg>
        </a>
      )}
    </div>
  </header>

  {project.cover && (
    <div class="reveal mx-auto mb-16 max-w-4xl">
      <DeviceFrame src={project.cover} alt={project.title} kind="laptop" eager={true} />
    </div>
  )}

  {project.caseStudy && (
    <section class="reveal mb-20 grid gap-3 sm:grid-cols-3">
      {project.caseStudy.metrics.map((m) => (
        <div class="rounded-xl border border-app bg-elevated/60 p-5">
          <p class="font-mono text-[10px] uppercase tracking-widest text-fg-subtle">
            {m.label[lang]}
          </p>
          <p class="mt-2 text-4xl font-semibold tracking-tight text-accent">
            {m.value}
          </p>
        </div>
      ))}
    </section>
  )}

  <div class="grid gap-12 md:grid-cols-[2fr_1fr]">
    <section class="reveal space-y-12">
      <div>
        <h2 class="mb-3 text-xl font-semibold text-fg">{t('projects.about')}</h2>
        <p class="text-pretty leading-relaxed text-fg-muted">{project.longDescription[lang]}</p>
      </div>

      {project.caseStudy && (
        <>
          <div>
            <h2 class="mb-3 flex items-center gap-3 text-xl font-semibold text-fg">
              <span class="font-mono text-xs text-accent">01.</span>
              {t('project.problem')}
            </h2>
            <p class="text-pretty leading-relaxed text-fg-muted">
              {project.caseStudy.problem[lang]}
            </p>
          </div>

          <div>
            <h2 class="mb-3 flex items-center gap-3 text-xl font-semibold text-fg">
              <span class="font-mono text-xs text-accent">02.</span>
              {t('project.solution')}
            </h2>
            <p class="text-pretty leading-relaxed text-fg-muted">
              {project.caseStudy.solution[lang]}
            </p>
          </div>

          <div>
            <h2 class="mb-3 flex items-center gap-3 text-xl font-semibold text-fg">
              <span class="font-mono text-xs text-accent">03.</span>
              {t('project.outcome')}
            </h2>
            <p class="text-pretty leading-relaxed text-fg-muted">
              {project.caseStudy.outcome[lang]}
            </p>
          </div>
        </>
      )}
    </section>

    <aside class="reveal space-y-6">
      <div class="sticky top-24 space-y-6">
        <div>
          <h2 class="mb-3 font-mono text-[10px] uppercase tracking-widest text-fg-subtle">
            {t('projects.tech')}
          </h2>
          <ul class="flex flex-wrap gap-2">
            {project.tags.map((tag) => (
              <li class="rounded-full border border-app bg-muted px-3 py-1 font-mono text-xs text-fg">
                {tag}
              </li>
            ))}
          </ul>
        </div>

        <div class="rounded-xl border border-app bg-elevated/60 p-5">
          <p class="font-mono text-[10px] uppercase tracking-widest text-fg-subtle">
            {t('projects.year')}
          </p>
          <p class="mt-1 text-2xl font-semibold text-fg">{project.year}</p>
        </div>
      </div>
    </aside>
  </div>

  {galleryItems.length > 0 && (
  <section class="reveal mt-24">
    <header class="mb-6 flex items-baseline justify-between">
      <h2 class="text-2xl font-semibold tracking-tight text-fg">
        {t('projects.gallery')}
      </h2>
      <span class="font-mono text-xs text-fg-subtle">
        ({String(galleryItems.length).padStart(2, '0')})
      </span>
    </header>

    <div class="grid items-start gap-x-8 gap-y-10 sm:grid-cols-2">
      {galleryItems.map((src, i) =>
          src.includes('mobile') ? (
            <div class="flex justify-center">
              <DeviceFrame src={src} alt={`${project.title} — ${i + 1}`} class="w-full max-w-[260px]" />
            </div>
          ) : (
            <DeviceFrame src={src} alt={`${project.title} — ${i + 1}`} />
          ),
        )}
    </div>
  </section>
  )}
</article>
