---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { profile } from '../data/profile';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const basePath = lang === 'es' ? '' : '/en';
const year = new Date().getFullYear();
---

<footer class="relative mt-12 border-t border-app/60">
  <div class="absolute inset-x-0 top-0 -z-10 h-px bg-gradient-to-r from-transparent via-accent/40 to-transparent" aria-hidden="true"></div>

  <div class="mx-auto max-w-6xl px-6 py-12">
    <div class="grid gap-8 sm:grid-cols-2 sm:items-end">
      <div>
        <p class="font-mono text-xs uppercase tracking-widest text-fg-subtle">
          {lang === 'es' ? 'Contacto' : 'Get in touch'}
        </p>
        <a
          href={`mailto:${profile.email}`}
          class="link-underline mt-2 inline-block text-2xl font-semibold tracking-tight text-fg hover:text-accent sm:text-3xl"
        >
          {profile.email}
        </a>
        <div class="mt-4 flex flex-wrap gap-4 font-mono text-xs">
          <a href={`${basePath}/cv`} class="link-underline text-fg-muted transition-colors hover:text-accent">
            {lang === 'es' ? 'Ver CV online →' : 'View CV online →'}
          </a>
          <a href={profile.cvPdf[lang]} download class="link-underline text-fg-muted transition-colors hover:text-accent">
            {lang === 'es' ? 'Descargar PDF ↓' : 'Download PDF ↓'}
          </a>
        </div>
      </div>

      <ul class="flex items-center gap-3 sm:justify-end">
        <li>
          <a href={profile.social.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-app text-fg-muted transition-all hover:-translate-y-0.5 hover:border-accent hover:text-accent">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.09 3.29 9.4 7.86 10.93.58.1.79-.25.79-.56 0-.28-.01-1.02-.02-2.01-3.2.7-3.87-1.54-3.87-1.54-.52-1.33-1.27-1.68-1.27-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.24 3.34.95.1-.74.4-1.24.73-1.53-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.05 0 0 .96-.31 3.15 1.18.91-.25 1.89-.38 2.86-.39.97.01 1.95.14 2.86.39 2.18-1.49 3.14-1.18 3.14-1.18.62 1.59.23 2.76.11 3.05.74.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.06.78 2.13 0 1.54-.01 2.78-.01 3.16 0 .31.21.67.8.56C20.71 21.4 24 17.09 24 12c0-6.35-5.15-11.5-11.5-11.5z"/>
            </svg>
          </a>
        </li>
        <li>
          <a href={profile.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-app text-fg-muted transition-all hover:-translate-y-0.5 hover:border-accent hover:text-accent">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.05c.47-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zm1.78 13.02H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/>
            </svg>
          </a>
        </li>
      </ul>
    </div>

    <div class="mt-10 flex flex-col items-start justify-between gap-3 border-t border-app/60 pt-6 font-mono text-xs text-fg-subtle sm:flex-row sm:items-center">
      <p>© {year} {profile.fullName}. {t('footer.rights')}</p>
      <p class="flex items-center gap-2">
        <span class="relative flex h-1.5 w-1.5">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent opacity-50"></span>
          <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-accent"></span>
        </span>
        {t('footer.built')}
      </p>
    </div>
  </div>
</footer>
