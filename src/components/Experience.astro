---
import ParticlesBg from './ParticlesBg.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { timeline } from '../data/profile';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const isCurrent = (period: string) => /presente|present/i.test(period);
---

<section id="experience" class="relative mx-auto max-w-6xl scroll-mt-20 overflow-x-clip px-6 py-32">
  <ParticlesBg density={24000} />
  <div class="pointer-events-none absolute inset-0 -z-20" aria-hidden="true">
    <div class="absolute -left-24 top-1/3 h-72 w-72 rounded-full bg-accent/8 blur-[100px]"></div>
  </div>
  <div class="absolute inset-x-0 top-0 -z-10 h-px bg-gradient-to-r from-transparent via-accent/30 to-transparent" aria-hidden="true"></div>

  <header class="reveal mb-20 max-w-2xl">
    <h2 class="text-balance text-4xl font-semibold tracking-[-0.03em] text-fg sm:text-5xl md:text-6xl">
      {t('experience.title')}
    </h2>
    <p class="mt-4 max-w-md text-pretty text-fg-muted">{t('experience.subtitle')}</p>
  </header>

  <ol class="relative">
    {
      timeline.map((entry) => (
        <li class="reveal group relative grid grid-cols-[24px_1fr] gap-x-5 rounded-2xl px-3 pt-3 -mx-3 -mt-3 transition-colors duration-300 hover:bg-elevated/50 md:grid-cols-[210px_24px_1fr] md:gap-x-10">
          <!-- Periodo + tipo (desktop, alineado a la derecha) -->
          <div class="hidden pt-1.5 text-right md:block">
            <p
              class:list={[
                'font-mono text-xs tracking-wide',
                isCurrent(entry.period) ? 'font-medium text-accent' : 'text-fg-subtle',
              ]}
            >
              {entry.period}
            </p>
            <p class="mt-1.5 font-mono text-[10px] uppercase tracking-[0.2em] text-fg-subtle/80">
              {entry.type === 'work' ? t('experience.work') : t('experience.education')}
            </p>
          </div>

          <!-- Riel: punto + línea -->
          <div class="relative flex justify-center">
            <span
              class:list={[
                'relative z-10 mt-1.5 flex h-3.5 w-3.5 items-center justify-center rounded-full',
                entry.type === 'work' ? 'bg-accent' : 'border-2 border-strong bg-app',
              ]}
            >
              {isCurrent(entry.period) && (
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent opacity-50" />
              )}
            </span>
            <span
              class="absolute top-7 bottom-1 w-px bg-gradient-to-b from-[rgb(var(--accent)/0.35)] to-[rgb(var(--border))] group-last:hidden"
              aria-hidden="true"
            />
          </div>

          <!-- Contenido -->
          <div class="pb-16 transition-transform duration-300 group-last:pb-0 md:group-hover:translate-x-1">
            <p
              class:list={[
                'mb-2 font-mono text-[11px] tracking-wide md:hidden',
                isCurrent(entry.period) ? 'text-accent' : 'text-fg-subtle',
              ]}
            >
              {entry.period} · {entry.type === 'work' ? t('experience.work') : t('experience.education')}
            </p>

            <h3 class="text-2xl font-semibold tracking-tight text-fg transition-colors group-hover:text-accent sm:text-3xl">
              {entry.role[lang]}
            </h3>
            <p class="mt-1.5 font-mono text-xs text-fg-muted">
              {entry.org}
              {isCurrent(entry.period) && (
                <span class="ml-2 inline-flex items-center gap-1.5 rounded-full bg-accent/10 px-2 py-0.5 font-mono text-[10px] uppercase tracking-widest text-accent">
                  <span class="h-1 w-1 rounded-full bg-accent" />
                  {lang === 'es' ? 'Actual' : 'Current'}
                </span>
              )}
            </p>

            <p class="mt-4 max-w-2xl text-pretty leading-relaxed text-fg-muted">
              {entry.description[lang]}
            </p>

            {entry.tech && (
              <ul class="mt-5 flex flex-wrap gap-2">
                {entry.tech.map((tech) => (
                  <li class="rounded-full border border-app bg-muted/60 px-2.5 py-0.5 font-mono text-[11px] text-fg-muted transition-colors group-hover:border-accent/30">
                    {tech}
                  </li>
                ))}
              </ul>
            )}
          </div>
        </li>
      ))
    }
  </ol>
</section>
