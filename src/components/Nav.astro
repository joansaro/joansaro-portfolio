---
import LangToggle from './LangToggle.astro';
import ThemeToggle from './ThemeToggle.astro';
import Logo from './Logo.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { profile } from '../data/profile';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const basePath = lang === 'es' ? '' : '/en';

const links = [
  { href: `${basePath}/#about`, label: t('nav.about'), section: 'about' },
  { href: `${basePath}/#experience`, label: t('experience.section'), section: 'experience' },
  { href: `${basePath}/#projects`, label: t('nav.projects'), section: 'projects' },
];
const contact = { href: `${basePath}/#contact`, label: t('nav.contact') };
---

<header class="sticky top-0 z-40 border-b border-app/60 bg-app/70 backdrop-blur-xl">
  <nav class="mx-auto flex h-16 max-w-6xl items-center gap-6 px-6">
    <Logo withWordmark={true} />

    <!-- Desktop: nav aligned to the right, next to the lang toggle -->
    <div class="ml-auto flex items-center gap-4">
      <ul class="hidden items-center gap-1 md:flex">
        {
          links.map((l) => (
            <li>
              <a
                href={l.href}
                data-spy-link={l.section}
                class="inline-flex items-center rounded-md px-3 py-1.5 text-sm text-fg-muted transition-colors hover:text-accent"
              >
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>

      <a
        href={contact.href}
        data-spy-link="contact"
        class="hidden items-center rounded-lg bg-accent px-4 py-2 text-sm font-medium text-[rgb(var(--bg))] transition-all hover:-translate-y-0.5 hover:bg-accent-soft md:inline-flex"
      >
        {contact.label}
      </a>

      <div class="hidden sm:flex sm:items-center sm:gap-2">
        <ThemeToggle />
        <LangToggle />
      </div>

      <!-- Mobile trigger: hamburger -->
      <button
        id="mobile-menu-toggle"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-app text-fg transition-colors hover:border-accent hover:text-accent md:hidden"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="4" y1="7" x2="20" y2="7"/>
          <line x1="4" y1="17" x2="20" y2="17"/>
        </svg>
      </button>
    </div>
  </nav>
</header>

<div
  id="mobile-menu"
  class="fixed inset-0 z-50 hidden flex-col bg-app/95 backdrop-blur-2xl md:hidden"
  aria-hidden="true"
>
  <div class="flex h-16 items-center justify-between px-6">
    <Logo withWordmark={true} />
    <button
      id="mobile-menu-close"
      type="button"
      aria-label="Close menu"
      class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-app text-fg transition-colors hover:border-accent hover:text-accent"
    >
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Full-screen menu: big links centered, footer pinned to the bottom -->
  <div class="flex flex-1 flex-col overflow-y-auto px-8 pb-10">
    <ul class="my-auto space-y-6">
      {
        [...links, contact].map((l, i) => (
          <li
            data-mobile-item
            style={`transition-delay: ${i * 60}ms`}
            class="opacity-0 translate-y-3 transition-all duration-500"
          >
            <a
              href={l.href}
              data-mobile-link
              class="block text-4xl font-semibold tracking-tight text-fg transition-all duration-300 hover:translate-x-2 hover:text-accent"
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="mt-auto space-y-5">
      <div class="flex gap-3">
        <a
          href={profile.social.github}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border border-app px-3.5 py-2 font-mono text-xs text-fg-muted transition-colors hover:border-accent hover:text-accent"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.17c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.28-1.68-1.28-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.19 1.76 1.19 1.03 1.75 2.69 1.25 3.34.95.1-.74.4-1.25.72-1.53-2.55-.29-5.23-1.28-5.23-5.68 0-1.25.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.1 11.1 0 0 1 5.78 0c2.21-1.49 3.18-1.18 3.18-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.09 0 4.41-2.69 5.38-5.25 5.67.41.35.77 1.05.77 2.12v3.14c0 .3.21.67.8.55A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"/></svg>
          GitHub
        </a>
        <a
          href={profile.social.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border border-app px-3.5 py-2 font-mono text-xs text-fg-muted transition-colors hover:border-accent hover:text-accent"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.94 5a2 2 0 1 1-4-.002 2 2 0 0 1 4 .002ZM7 8.48H3V21h4V8.48Zm6.32 0H9.34V21h3.94v-6.57c0-3.66 4.77-4 4.77 0V21H22v-7.93c0-6.17-7.06-5.94-8.72-2.91l.04-1.68Z"/></svg>
          LinkedIn
        </a>
      </div>
      <div class="flex items-center justify-between border-t border-app/60 pt-6">
        <p class="inline-flex items-center gap-2 font-mono text-xs text-fg-subtle">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent opacity-70"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-accent"></span>
          </span>
          {t('contact.cta')}
        </p>
        <div class="flex items-center gap-2">
          <ThemeToggle />
          <LangToggle />
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function setupMobileMenu() {
    const toggle = document.getElementById('mobile-menu-toggle');
    const closeBtn = document.getElementById('mobile-menu-close');
    const menu = document.getElementById('mobile-menu');
    if (!toggle || !menu || !closeBtn) return;
    if (toggle.dataset.bound === '1') return;
    toggle.dataset.bound = '1';

    const items = menu.querySelectorAll<HTMLElement>('[data-mobile-item]');
    const links = menu.querySelectorAll<HTMLElement>('[data-mobile-link]');

    const open = () => {
      menu.classList.remove('hidden');
      menu.classList.add('flex');
      menu.setAttribute('aria-hidden', 'false');
      toggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      requestAnimationFrame(() => {
        items.forEach((el) => el.classList.remove('opacity-0', 'translate-y-3'));
      });
    };

    const close = () => {
      items.forEach((el) => el.classList.add('opacity-0', 'translate-y-3'));
      menu.classList.add('hidden');
      menu.classList.remove('flex');
      menu.setAttribute('aria-hidden', 'true');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    };

    toggle.addEventListener('click', open);
    closeBtn.addEventListener('click', close);
    links.forEach((a) => a.addEventListener('click', close));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !menu.classList.contains('hidden')) close();
    });
  }
  setupMobileMenu();
  document.addEventListener('astro:page-load', setupMobileMenu);

  // --- Scrollspy: highlight the section currently in view ---
  let spyObserver: IntersectionObserver | null = null;

  function setupScrollSpy() {
    spyObserver?.disconnect();
    const sections = ['about', 'experience', 'projects', 'contact']
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => Boolean(el));
    const linksBySection = new Map<string, HTMLElement[]>();
    document.querySelectorAll<HTMLElement>('[data-spy-link]').forEach((a) => {
      const key = a.dataset.spyLink!;
      linksBySection.set(key, [...(linksBySection.get(key) ?? []), a]);
    });
    if (sections.length === 0 || linksBySection.size === 0) return;

    const setActive = (id: string | null) => {
      linksBySection.forEach((els, key) => {
        const on = key === id;
        els.forEach((el) => {
          if (key === 'contact') {
            el.classList.toggle('ring-2', on);
            el.classList.toggle('ring-accent/50', on);
          } else {
            el.classList.toggle('text-accent', on);
            el.classList.toggle('text-fg-muted', !on);
          }
        });
      });
    };

    spyObserver = new IntersectionObserver(
      (entries) => {
        const visible = entries.filter((e) => e.isIntersecting);
        if (visible.length > 0) setActive(visible[0].target.id);
      },
      { rootMargin: '-35% 0px -55% 0px' },
    );
    sections.forEach((el) => spyObserver!.observe(el));
  }
  setupScrollSpy();
  document.addEventListener('astro:page-load', setupScrollSpy);
</script>
