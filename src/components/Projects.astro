---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { projects } from '../data/profile';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const basePath = lang === 'es' ? '' : '/en';

const live = projects.filter((p) => p.status !== 'coming-soon');
const apps = live.filter((p) => p.featured);
const sites = live.filter((p) => !p.featured);
const upcoming = projects.filter((p) => p.status === 'coming-soon');
const inProduction = lang === 'es' ? 'Proyecto real' : 'Real project';
---

<section id="projects" class="relative mx-auto max-w-6xl scroll-mt-20 px-6 py-32">
  <div class="absolute inset-x-0 top-0 -z-10 h-px bg-gradient-to-r from-transparent via-accent/30 to-transparent" aria-hidden="true"></div>

  <header class="reveal mb-16 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div class="max-w-2xl">
      <p class="section-number mb-4 font-mono text-xs uppercase tracking-[0.25em] text-accent">03 / {t('nav.projects')}</p>
      <h2 class="text-balance text-4xl font-semibold tracking-[-0.03em] text-fg sm:text-5xl md:text-6xl">
        {t('projects.title')}
      </h2>
      <p class="mt-4 max-w-md text-pretty text-fg-muted">{t('projects.subtitle')}</p>
    </div>
    <div class="hidden font-mono text-xs text-fg-subtle sm:block">
      ({String(projects.length).padStart(2, '0')}) {t('nav.projects')}
    </div>
  </header>

  <!-- Real personal projects — case studies landing soon -->
  {upcoming.length > 0 && (
    <div class="mb-16">
      <p class="reveal mb-6 font-mono text-xs uppercase tracking-[0.25em] text-fg-subtle">
        {lang === 'es' ? 'En producción — sistemas reales' : 'In production — real systems'}
      </p>
      <ul class="grid gap-6 md:grid-cols-2">
        {
          upcoming.map((p) => (
            <li class="reveal relative overflow-hidden rounded-2xl border border-dashed border-strong bg-elevated/20 p-6">
              <div class="mb-3 flex items-center justify-between gap-3">
                <span
                  class:list={[
                    'rounded-full px-3 py-1 font-mono text-[11px] uppercase tracking-widest',
                    p.demo ? 'bg-emerald-400/10 text-emerald-400' : 'bg-accent/10 text-accent',
                  ]}
                >
                  {p.demo ? (lang === 'es' ? 'En línea' : 'Live') : (lang === 'es' ? 'Código privado' : 'Private code')}
                </span>
                <span class="font-mono text-[11px] uppercase tracking-widest text-fg-subtle">{inProduction}</span>
              </div>
              <h3 class="mb-2 text-xl font-semibold tracking-tight text-fg">
                <a href={`${basePath}/projects/${p.slug}`} class="transition-colors hover:text-accent">{p.title}</a>
              </h3>
              <p class="mb-4 text-sm text-pretty text-fg-muted">{p.description[lang]}</p>
              <ul class="flex flex-wrap gap-2">
                {p.tags.map((tag) => (
                  <li class="rounded-full border border-app bg-muted px-2.5 py-0.5 font-mono text-[11px] text-fg-muted">
                    {tag}
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex flex-wrap items-center gap-5">
                <a
                  href={`${basePath}/projects/${p.slug}`}
                  class="group inline-flex items-center gap-1.5 font-mono text-sm text-accent transition-colors hover:text-accent-soft"
                >
                  {lang === 'es' ? 'Ver caso de estudio' : 'View case study'}
                  <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M5 12h14M13 5l7 7-7 7" />
                  </svg>
                </a>
                {p.demo && (
                  <a
                    href={p.demo}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group inline-flex items-center gap-1.5 font-mono text-sm text-fg-muted transition-colors hover:text-accent"
                  >
                    {lang === 'es' ? 'Ver sitio' : 'Visit site'}
                    <svg class="h-3.5 w-3.5 transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M7 17 17 7M7 7h10v10" />
                    </svg>
                  </a>
                )}
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  )}

  <p class="reveal mb-6 font-mono text-xs uppercase tracking-[0.25em] text-fg-subtle">
    {lang === 'es' ? 'Aplicaciones — proyectos personales' : 'Apps — personal projects'}
  </p>
  <ul class="space-y-6">
    {
      apps.map((p, i) => (
        <li class="reveal group">
          <a
            href={`${basePath}/projects/${p.slug}`}
            class="relative flex flex-col gap-6 overflow-hidden rounded-2xl border border-app bg-elevated/40 p-5 transition-all duration-500 hover:border-accent/60 hover:bg-elevated md:flex-row md:items-center md:gap-8 md:p-6"
          >
            <span class="pointer-events-none absolute inset-0 -z-10 opacity-0 transition-opacity duration-500 group-hover:opacity-100" aria-hidden="true">
              <span class="absolute inset-0 bg-gradient-to-br from-accent/8 via-transparent to-transparent"></span>
            </span>

            <div class="relative aspect-[16/10] w-full shrink-0 overflow-hidden rounded-xl border border-app bg-muted md:w-[44%]">
              <img
                src={p.cover}
                alt={p.title}
                loading="lazy"
                decoding="async"
                class="h-full w-full object-cover object-top transition-transform duration-700 group-hover:scale-[1.04]"
              />
              <div class="pointer-events-none absolute inset-0 bg-gradient-to-tr from-app/40 via-transparent to-transparent" aria-hidden="true"></div>
            </div>

            <div class="flex flex-1 flex-col">
              <div class="mb-3 flex items-baseline gap-3 font-mono text-xs text-fg-subtle">
                <span class="text-accent">{String(i + 1).padStart(2, '0')}</span>
                <span class="h-px flex-1 bg-app"></span>
                <span>{p.year}</span>
              </div>

              <h3 class="mb-3 text-2xl font-semibold tracking-tight text-fg transition-colors group-hover:text-accent sm:text-3xl">
                {p.title}
              </h3>

              <p class="mb-5 max-w-xl text-pretty text-fg-muted">
                {p.description[lang]}
              </p>

              <ul class="mb-6 flex flex-wrap gap-2">
                {p.tags.map((tag) => (
                  <li class="rounded-full border border-app bg-muted px-2.5 py-0.5 font-mono text-[11px] text-fg-muted">
                    {tag}
                  </li>
                ))}
              </ul>

              <div class="mt-auto flex items-center justify-between">
                <span class="inline-flex items-center gap-1.5 font-mono text-xs uppercase tracking-widest text-accent">
                  {t('projects.viewMore')}
                  <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M5 12h14M13 5l7 7-7 7"/>
                  </svg>
                </span>
              </div>
            </div>
          </a>
        </li>
      ))
    }
  </ul>

  <!-- Websites: compact grid in a single sub-section -->
  {sites.length > 0 && (
    <div class="mt-14">
      <p class="reveal mb-6 font-mono text-xs uppercase tracking-[0.25em] text-fg-subtle">
        {lang === 'es' ? 'Sitios web — diseño y front' : 'Websites — design & front-end'}
      </p>
      <ul class="grid gap-5 sm:grid-cols-2">
        {
          sites.map((p) => (
            <li class="reveal group min-w-0">
              <a
                href={`${basePath}/projects/${p.slug}`}
                class="flex h-full items-center gap-4 overflow-hidden rounded-2xl border border-app bg-elevated/40 p-4 transition-all duration-300 hover:border-accent/60 hover:bg-elevated"
              >
                <div class="relative aspect-[16/11] w-36 shrink-0 overflow-hidden rounded-lg border border-app bg-muted sm:w-44">
                  <img
                    src={p.cover}
                    alt={p.title}
                    loading="lazy"
                    decoding="async"
                    class="h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-[1.05]"
                  />
                </div>
                <div class="min-w-0 flex-1">
                  <div class="mb-1 flex items-baseline justify-between gap-3">
                    <h3 class="truncate text-base font-semibold tracking-tight text-fg transition-colors group-hover:text-accent">
                      {p.title}
                    </h3>
                    <span class="font-mono text-[11px] text-fg-subtle">{p.year}</span>
                  </div>
                  <p class="mb-2 line-clamp-2 text-sm text-fg-muted">{p.description[lang]}</p>
                  <div class="flex flex-wrap gap-1.5">
                    {p.tags.slice(0, 3).map((tag) => (
                      <span class="rounded-full border border-app bg-muted px-2 py-0.5 font-mono text-[10px] text-fg-muted">
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  )}

</section>
