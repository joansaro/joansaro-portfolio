---
import { getLangFromUrl } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const pathname = Astro.url.pathname.replace(/^\/(es|en)(\/|$)/, '/');
const targetLang = lang === 'es' ? 'en' : 'es';
const targetHref = targetLang === 'es' ? pathname : `/en${pathname === '/' ? '' : pathname}`;
---

<a
  href={targetHref}
  data-lang-toggle={targetLang}
  aria-label={`Switch to ${targetLang.toUpperCase()}`}
  class="group inline-flex h-9 items-center justify-center gap-1 rounded-md border border-app px-3 font-mono text-[11px] font-medium tracking-[0.15em] text-fg-muted transition-all hover:text-accent hover:border-accent"
>
  <span class:list={[lang === 'es' ? 'text-fg' : '']}>ES</span>
  <span class="text-fg-subtle">/</span>
  <span class:list={[lang === 'en' ? 'text-fg' : '']}>EN</span>
</a>

<script>
  function setupLangToggle() {
    document.querySelectorAll<HTMLElement>('[data-lang-toggle]').forEach((el) => {
      if (el.dataset.bound === '1') return;
      el.dataset.bound = '1';
      el.addEventListener('click', () => {
        try {
          localStorage.setItem('preferred-lang', el.getAttribute('data-lang-toggle') || '');
        } catch {}
      });
    });
  }
  setupLangToggle();
  document.addEventListener('astro:page-load', setupLangToggle);
</script>
