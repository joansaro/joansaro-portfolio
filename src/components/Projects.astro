---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { projects } from '../data/profile';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const basePath = lang === 'es' ? '' : '/en';

const live = projects.filter((p) => p.status !== 'coming-soon');
const apps = live.filter((p) => p.featured);
const sites = live.filter((p) => !p.featured);
const upcoming = projects.filter((p) => p.status === 'coming-soon');
const inProduction = lang === 'es' ? 'Proyecto real' : 'Real project';
---

<section id="projects" class="relative mx-auto max-w-6xl scroll-mt-20 overflow-x-clip px-6 py-32">
  <div class="absolute inset-x-0 top-0 -z-10 h-px bg-gradient-to-r from-transparent via-accent/30 to-transparent" aria-hidden="true"></div>
  <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
    <svg class="absolute bottom-20 left-2 h-44 w-60" viewBox="0 0 240 180" fill="none">
      <path d="M20 140 L70 90 L128 118 L170 40 L216 66" stroke="rgb(var(--accent) / 0.15)" stroke-width="1" />
      <circle cx="20" cy="140" r="2.5" fill="rgb(var(--accent) / 0.4)" />
      <circle cx="70" cy="90" r="3.5" fill="rgb(var(--accent) / 0.5)" />
      <circle cx="128" cy="118" r="2" fill="rgb(var(--accent) / 0.3)" />
      <circle cx="170" cy="40" r="3" fill="rgb(var(--accent) / 0.45)" />
      <circle cx="216" cy="66" r="2" fill="rgb(var(--text-subtle) / 0.5)" />
    </svg>
  </div>

  <header class="reveal mb-16 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div class="max-w-2xl">
      <h2 class="text-balance text-4xl font-semibold tracking-[-0.03em] text-fg sm:text-5xl md:text-6xl">
        {t('projects.title')}
      </h2>
      <p class="mt-4 max-w-md text-pretty text-fg-muted">{t('projects.subtitle')}</p>
    </div>
    <div class="hidden font-mono text-xs text-fg-subtle sm:block">
      ({String(projects.length).padStart(2, '0')}) {t('nav.projects')}
    </div>
  </header>

  <!-- Real personal projects — case studies landing soon -->
  {upcoming.length > 0 && (
    <div class="mb-16">
      <p class="reveal mb-6 font-mono text-xs uppercase tracking-[0.25em] text-fg-subtle">
        {lang === 'es' ? 'En producción — sistemas reales' : 'In production — real systems'}
      </p>
      <ul class="grid gap-6 md:grid-cols-2">
        {
          upcoming.map((p) => (
            <li class="reveal relative overflow-hidden rounded-2xl border border-dashed border-strong bg-elevated/20 p-6 transition-all duration-300 hover:border-accent/40 hover:bg-elevated/70">
              <div class="mb-3 flex items-center justify-between gap-3">
                <span
                  class:list={[
                    'rounded-full px-3 py-1 font-mono text-[11px] uppercase tracking-widest',
                    p.demo ? 'bg-emerald-500/10 text-emerald-600 dark:text-emerald-400' : 'bg-accent/10 text-accent',
                  ]}
                >
                  {p.demo ? (lang === 'es' ? 'En línea' : 'Live') : (lang === 'es' ? 'Código privado' : 'Private code')}
                </span>
                <span class="font-mono text-[11px] uppercase tracking-widest text-fg-subtle">{inProduction}</span>
              </div>
              <h3 class="mb-2 text-xl font-semibold tracking-tight text-fg">
                <a href={`${basePath}/projects/${p.slug}`} class="transition-colors hover:text-accent">{p.title}</a>
              </h3>
              <p class="mb-4 text-sm text-pretty text-fg-muted">{p.description[lang]}</p>
              <ul class="flex flex-wrap gap-2">
                {p.tags.map((tag) => (
                  <li class="rounded-full border border-app bg-muted px-2.5 py-0.5 font-mono text-[11px] text-fg-muted">
                    {tag}
                  </li>
                ))}
              </ul>
              <div class="mt-6 flex flex-wrap items-center gap-3">
                <a
                  href={`${basePath}/projects/${p.slug}`}
                  class="inline-flex items-center rounded-lg bg-accent px-5 py-2.5 text-sm font-medium text-white shadow-md shadow-accent/20 transition-all hover:-translate-y-0.5 hover:bg-accent-hover"
                >
                  {lang === 'es' ? 'Ver caso de estudio' : 'View case study'}
                </a>
                {p.demo && (
                  <a
                    href={p.demo}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 rounded-lg border border-strong px-5 py-2.5 text-sm font-medium text-fg transition-all hover:-translate-y-0.5 hover:border-accent hover:text-accent"
                  >
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7M7 7h10v10" /></svg>
                    {lang === 'es' ? 'Ver sitio' : 'Visit site'}
                  </a>
                )}
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  )}

  <p class="reveal mb-6 font-mono text-xs uppercase tracking-[0.25em] text-fg-subtle">
    {lang === 'es' ? 'Aplicaciones — proyectos personales' : 'Apps — personal projects'}
  </p>
  <ul class="space-y-6">
    {
      apps.map((p) => (
        <li class="reveal group">
          <div class="relative flex flex-col gap-6 overflow-hidden rounded-2xl border border-app bg-elevated/40 p-5 transition-all duration-500 hover:border-accent/60 hover:bg-elevated md:flex-row md:items-center md:gap-8 md:p-6">
            <span class="pointer-events-none absolute inset-0 -z-10 opacity-0 transition-opacity duration-500 group-hover:opacity-100" aria-hidden="true">
              <span class="absolute inset-0 bg-gradient-to-br from-accent/8 via-transparent to-transparent"></span>
            </span>

            <a
              href={`${basePath}/projects/${p.slug}`}
              class="relative block aspect-[16/10] w-full shrink-0 overflow-hidden rounded-xl border border-app bg-muted md:w-[44%]"
              aria-label={p.title}
            >
              <img
                src={p.cover}
                alt={p.title}
                loading="lazy"
                decoding="async"
                class="h-full w-full object-cover object-top transition-transform duration-700 group-hover:scale-[1.04]"
              />
              <div class="pointer-events-none absolute inset-0 bg-gradient-to-tr from-app/40 via-transparent to-transparent" aria-hidden="true"></div>
            </a>

            <div class="flex flex-1 flex-col">
              <p class="mb-3 font-mono text-xs text-fg-subtle">{p.year}</p>

              <h3 class="mb-3 text-2xl font-semibold tracking-tight text-fg sm:text-3xl">
                <a href={`${basePath}/projects/${p.slug}`} class="transition-colors group-hover:text-accent">
                  {p.title}
                </a>
              </h3>

              <p class="mb-5 max-w-xl text-pretty text-fg-muted">
                {p.description[lang]}
              </p>

              <ul class="mb-6 flex flex-wrap gap-2">
                {p.tags.map((tag) => (
                  <li class="rounded-full border border-app bg-muted px-2.5 py-0.5 font-mono text-[11px] text-fg-muted">
                    {tag}
                  </li>
                ))}
              </ul>

              <div class="mt-auto flex flex-wrap items-center gap-3">
                <a
                  href={`${basePath}/projects/${p.slug}`}
                  class="inline-flex items-center rounded-lg bg-accent px-5 py-2.5 text-sm font-medium text-white shadow-md shadow-accent/20 transition-all hover:-translate-y-0.5 hover:bg-accent-hover"
                >
                  {t('projects.viewMore')}
                </a>
                {p.demo && (
                  <a
                    href={p.demo}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 rounded-lg border border-strong px-5 py-2.5 text-sm font-medium text-fg transition-all hover:-translate-y-0.5 hover:border-accent hover:text-accent"
                  >
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7M7 7h10v10" /></svg>
                    {t('projects.viewDemo')}
                  </a>
                )}
                {p.code && (
                  <a
                    href={p.code}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 rounded-lg border border-strong px-5 py-2.5 text-sm font-medium text-fg transition-all hover:-translate-y-0.5 hover:border-accent hover:text-accent"
                  >
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.17c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.28-1.68-1.28-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.19 1.76 1.19 1.03 1.75 2.69 1.25 3.34.95.1-.74.4-1.25.72-1.53-2.55-.29-5.23-1.28-5.23-5.68 0-1.25.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.1 11.1 0 0 1 5.78 0c2.21-1.49 3.18-1.18 3.18-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.09 0 4.41-2.69 5.38-5.25 5.67.41.35.77 1.05.77 2.12v3.14c0 .3.21.67.8.55A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"/></svg>
                    {t('projects.viewCode')}
                  </a>
                )}
              </div>
            </div>
          </div>
        </li>
      ))
    }
  </ul>

  <!-- Websites: compact grid in a single sub-section -->
  {sites.length > 0 && (
    <div class="mt-14">
      <p class="reveal mb-6 font-mono text-xs uppercase tracking-[0.25em] text-fg-subtle">
        {lang === 'es' ? 'Sitios web — diseño y front' : 'Websites — design & front-end'}
      </p>
      <ul class="grid gap-5 sm:grid-cols-2">
        {
          sites.map((p) => (
            <li class="reveal group min-w-0">
              <a
                href={`${basePath}/projects/${p.slug}`}
                class="flex h-full items-center gap-4 overflow-hidden rounded-2xl border border-app bg-elevated/40 p-4 transition-all duration-300 hover:border-accent/60 hover:bg-elevated"
              >
                <div class="relative aspect-[16/11] w-36 shrink-0 overflow-hidden rounded-lg border border-app bg-muted sm:w-44">
                  <img
                    src={p.cover}
                    alt={p.title}
                    loading="lazy"
                    decoding="async"
                    class="h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-[1.05]"
                  />
                </div>
                <div class="min-w-0 flex-1">
                  <div class="mb-1 flex items-baseline justify-between gap-3">
                    <h3 class="truncate text-base font-semibold tracking-tight text-fg transition-colors group-hover:text-accent">
                      {p.title}
                    </h3>
                    <span class="font-mono text-[11px] text-fg-subtle">{p.year}</span>
                  </div>
                  <p class="mb-2 line-clamp-2 text-sm text-fg-muted">{p.description[lang]}</p>
                  <div class="flex flex-wrap gap-1.5">
                    {p.tags.slice(0, 3).map((tag) => (
                      <span class="rounded-full border border-app bg-muted px-2 py-0.5 font-mono text-[10px] text-fg-muted">
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  )}

</section>
