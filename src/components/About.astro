---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { profile } from '../data/profile';
import { brandIcons } from '../data/tech-icons';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Icono de marca por ítem del stack (Simple Icons, monocromo)
const iconSlug = (item: string): string | null => {
  if (item.startsWith('React')) return 'react';
  if (item === 'TypeScript') return 'typescript';
  if (item.startsWith('Next')) return 'nextdotjs';
  if (item === 'Astro') return 'astro';
  if (item.startsWith('Tailwind')) return 'tailwindcss';
  if (item === 'NestJS') return 'nestjs';
  if (item.startsWith('Node')) return 'nodedotjs';
  if (item === 'PostgreSQL') return 'postgresql';
  if (item.startsWith('TypeORM')) return 'prisma';
  if (item.startsWith('REST')) return 'jsonwebtokens';
  if (item.startsWith('WordPress')) return 'wordpress';
  if (item.startsWith('Square')) return 'square';
  if (item === 'Docker') return 'docker';
  if (item.startsWith('Git')) return 'github';
  return null;
};
const isPos = (item: string) => item.startsWith('POS') || item.startsWith('Retail POS');
const isAi = (item: string) => item.includes('IA') || item.startsWith('AI-');

const stackGroups = [
  { label: t('about.frontend'), items: profile.stack.frontend, icon: 'code' },
  { label: t('about.backend'), items: profile.stack.backend, icon: 'server' },
  { label: t('about.tools'), items: profile.stack.tools[lang], icon: 'wrench' },
] as const;
---

<section id="about" class="relative mx-auto max-w-6xl scroll-mt-20 overflow-x-clip px-6 py-32">
  <header class="reveal mb-14">
    <h2 class="text-balance text-4xl font-semibold tracking-[-0.03em] text-fg sm:text-5xl md:text-6xl">
      {t('about.title')}
    </h2>
  </header>

  <div class="grid gap-12 md:grid-cols-[1fr_2fr] md:gap-16">
    <div class="reveal">
      <div class="hidden md:block">
        <div class="rounded-xl border border-app bg-elevated p-5">
          <div class="flex items-center gap-3 border-b border-app pb-3 mb-3">
            <svg class="h-5 w-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m4 6 8-4 8 4"/>
              <path d="m18 10 4 2v3"/>
              <path d="M14 22v-4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v4"/>
              <path d="M18 5v17"/>
              <path d="M6 5v17"/>
              <circle cx="12" cy="9" r="2"/>
            </svg>
            <p class="font-mono text-[10px] uppercase tracking-widest text-fg-subtle">
              {lang === 'es' ? 'Educación' : 'Education'}
            </p>
          </div>
          <p class="text-sm font-medium text-fg">{profile.education[lang]}</p>
        </div>
      </div>
    </div>

    <div class="space-y-6">
      <div class="reveal space-y-5 text-lg leading-relaxed text-fg-muted">
        <p class="text-pretty">{t('about.p1')}</p>
        <p class="text-pretty">{t('about.p2')}</p>
      </div>

      <div class="reveal md:hidden">
        <div class="rounded-xl border border-app bg-elevated p-5">
          <div class="flex items-center gap-3 border-b border-app pb-3 mb-3">
            <svg class="h-5 w-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m4 6 8-4 8 4"/>
              <path d="m18 10 4 2v3"/>
              <path d="M14 22v-4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v4"/>
              <path d="M18 5v17"/>
              <path d="M6 5v17"/>
              <circle cx="12" cy="9" r="2"/>
            </svg>
            <p class="font-mono text-[10px] uppercase tracking-widest text-fg-subtle">
              {lang === 'es' ? 'Educación' : 'Education'}
            </p>
          </div>
          <p class="text-sm font-medium text-fg">{profile.education[lang]}</p>
        </div>
      </div>

    </div>
  </div>

  <div class="reveal mt-14 grid gap-6 sm:grid-cols-3">
    {stackGroups.map((group) => (
      <div class="group rounded-xl border border-app bg-elevated/40 p-6 transition-all hover:-translate-y-0.5 hover:border-accent/40 hover:bg-elevated">
        <p class="mb-5 flex items-center gap-2.5 font-mono text-[11px] font-semibold uppercase tracking-widest text-fg-subtle">
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-accent/10 text-accent">
            {group.icon === 'code' && (
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m16 18 6-6-6-6M8 6l-6 6 6 6" />
              </svg>
            )}
            {group.icon === 'server' && (
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect width="20" height="8" x="2" y="2" rx="2" ry="2" />
                <rect width="20" height="8" x="2" y="14" rx="2" ry="2" />
                <line x1="6" x2="6.01" y1="6" y2="6" />
                <line x1="6" x2="6.01" y1="18" y2="18" />
              </svg>
            )}
            {group.icon === 'wrench' && (
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
              </svg>
            )}
          </span>
          {group.label}
        </p>
        <ul class="space-y-2.5">
          {group.items.map((item) => (
            <li class="tech-item flex items-center gap-2.5 text-sm text-fg">
              <span class="tech-icon inline-flex h-4 w-4 shrink-0 items-center justify-center">
                {iconSlug(item) ? (
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d={brandIcons[iconSlug(item)!]} />
                  </svg>
                ) : isPos(item) ? (
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M3 5v14M8 5v14M12 5v14M17 5v14M21 5v14" />
                  </svg>
                ) : isAi(item) ? (
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 3v3m0 12v3M5.6 5.6l2.1 2.1m8.6 8.6 2.1 2.1M3 12h3m12 0h3M5.6 18.4l2.1-2.1m8.6-8.6 2.1-2.1" />
                  </svg>
                ) : (
                  <span class="text-accent">›</span>
                )}
              </span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>
